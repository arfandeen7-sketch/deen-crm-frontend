# =============================================================
# DEEN CRM Frontend — Environment Variables
# Copy this file content into .env.local and adjust as needed.
# =============================================================

# ── API Base URL ──────────────────────────────────────────────
# Development (local backend): http://localhost:3001
# Production (Railway):        https://deen-crm-backend-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Demo / Mock Auth ─────────────────────────────────────────
# "false" = real backend required; disables the demo-login shortcut.
# "true" (or omit) = allow demo login with admin@gmail.com / Admin@123.
# Always set to "false" in production.
NEXT_PUBLIC_DEMO_AUTH=false
